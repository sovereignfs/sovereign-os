#!/bin/sh

set -eu

state_dir=/data/sovereign
app_dir=${state_dir}/apps/pihole
secret_dir=${state_dir}/secrets
password_file=${secret_dir}/pihole-admin-password
compose_file=${app_dir}/compose.yaml
appliance_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
release_root=$(CDPATH= cd -- "${appliance_root}/.." && pwd)
template=${appliance_root}/pihole/compose.yaml.in
marker=${state_dir}/pihole-ready
auth_request=$(mktemp)
auth_response=$(mktemp)
trap 'rm -f "$auth_request" "$auth_response"' EXIT
image_environment=${release_root}/pihole-image.env
. "$image_environment"
image_reference="${PIHOLE_IMAGE_REPOSITORY#docker.io/}@${PIHOLE_IMAGE_DIGEST}"

install -d -m 0755 "$state_dir" "$app_dir" "${app_dir}/etc-pihole"
install -d -m 0700 "$secret_dir"

if [ ! -s "$password_file" ]; then
  umask 077
  od -An -N18 -tx1 /dev/urandom | tr -d ' \n' > "${password_file}.tmp"
  printf '\n' >> "${password_file}.tmp"
  mv "${password_file}.tmp" "$password_file"
fi
chmod 0600 "$password_file"

sed "s|@PIHOLE_IMAGE_REFERENCE@|${image_reference}|g" \
  "$template" > "${compose_file}.tmp"
chmod 0644 "${compose_file}.tmp"
mv "${compose_file}.tmp" "$compose_file"

docker compose \
  --project-name sovereign-pihole \
  --file "$compose_file" \
  up --detach --no-build --pull never

attempt=0
while [ "$attempt" -lt 90 ]; do
  health=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{end}}' pihole 2>/dev/null || true)
  [ "$health" = healthy ] && break
  attempt=$((attempt + 1))
  sleep 2
done

test "${health:-}" = healthy
dig +short +time=3 +tries=1 @127.0.0.1 pi.hole | grep -q .
curl --fail --silent --show-error --max-time 10 \
  --output /dev/null http://127.0.0.1:8080/admin/

# A healthy login page is insufficient: verify that the device credential and
# Pi-hole's effective API password are the same before recording readiness.
chmod 0600 "$auth_request" "$auth_response"
python3 -c 'import json, sys; json.dump({"password": sys.stdin.read().rstrip("\n")}, sys.stdout)' \
  < "$password_file" > "$auth_request"
curl --fail --silent --show-error --max-time 10 \
  --header 'Content-Type: application/json' \
  --request POST \
  --data-binary "@$auth_request" \
  --output "$auth_response" \
  http://127.0.0.1:8080/api/auth
grep -Eq '"valid"[[:space:]]*:[[:space:]]*true' "$auth_response"

{
  printf 'image=%s\n' "$(docker inspect --format '{{.Image}}' pihole)"
  printf 'health=%s\n' "$health"
  printf 'dns=pass\n'
  printf 'http=pass\n'
  printf 'credential=pass\n'
} > "${marker}.tmp"
mv "${marker}.tmp" "$marker"
