#!/bin/sh

set -eu

docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{end}}' pihole |
  grep -qx healthy
dig +tcp +short +time=3 +tries=1 @127.0.0.1 pi.hole | grep -q .
dig +notcp +short +time=3 +tries=1 @127.0.0.1 pi.hole | grep -q .
curl --fail --silent --show-error --max-time 10 \
  --output /dev/null http://127.0.0.1:8080/admin/
nginx -t
curl --fail --silent --show-error --max-time 10 \
  --output /dev/null http://127.0.0.1/dns/admin/
test "$(curl --silent --output /dev/null --write-out '%{http_code}' \
  --max-time 10 http://127.0.0.1/admin/)" = 404
test "$(curl --silent --output /dev/null --write-out '%{http_code}' \
  --max-time 10 http://127.0.0.1/api/)" = 404
findmnt -rn -o TARGET /data | grep -qx /data
