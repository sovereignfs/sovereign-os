[Unit]
Description=Configure and start the Sovereign Pi-hole appliance
Requires=sovereign-pihole-import.service docker.service
After=sovereign-imager-provision.service sovereign-pihole-import.service sovereign-update-recovery.service docker.service network-online.target
Wants=sovereign-imager-provision.service sovereign-update-recovery.service network-online.target
RequiresMountsFor=/data
ConditionPathIsMountPoint=/data

[Service]
Type=oneshot
ExecStart=/usr/lib/sovereign/start-pihole
RemainAfterExit=yes
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=multi-user.target
