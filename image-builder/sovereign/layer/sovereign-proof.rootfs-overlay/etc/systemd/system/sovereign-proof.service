[Unit]
Description=Initialize the Sovereign proof data directory
Requires=sovereign-data-expand.service
RequiresMountsFor=/data
After=local-fs.target sovereign-data-expand.service
ConditionPathIsMountPoint=/data

[Service]
Type=oneshot
ExecStart=/usr/lib/sovereign/proof-init
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
