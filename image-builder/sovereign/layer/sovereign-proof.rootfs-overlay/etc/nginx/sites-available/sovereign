server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name sovereign.local sovereign _;
    server_tokens off;

    location = / {
        return 302 /dns/admin/;
    }

    location = /dns {
        return 308 /dns/admin/;
    }

    location = /dns/ {
        return 308 /dns/admin/;
    }

    location /dns/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /dns;
        proxy_redirect off;
    }

    location = /admin {
        return 404;
    }

    location ^~ /admin/ {
        return 404;
    }

    location = /api {
        return 404;
    }

    location ^~ /api/ {
        return 404;
    }

    location / {
        return 404;
    }
}
