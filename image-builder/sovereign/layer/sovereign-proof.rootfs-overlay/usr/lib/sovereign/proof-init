#!/bin/sh

set -eu

install -d -m 0755 /data/sovereign /data/sovereign/configuration
install -d -m 0700 /data/sovereign/backups /data/sovereign/update-state
version=$(sed -n 's/^VERSION="\(.*\)"$/\1/p' /etc/sovereign-release)
test -n "$version"
release_dir="/opt/sovereign/releases/$version"
test -d "$release_dir/appliance"
test -f "$release_dir/sovereign-release"
test -f "$release_dir/pihole-image.env"
test -x "$release_dir/appliance/bin/start-pihole"
test -x "$release_dir/appliance/bin/stop-pihole"
test -x "$release_dir/appliance/bin/console-health"
test -x "$release_dir/appliance/bin/verify-local-access"
test -x "$release_dir/appliance/bin/verify-update-health"
test -f "$release_dir/appliance/pihole/compose.yaml.in"
test -f "$release_dir/appliance/nginx/sovereign.conf"
test -f "$release_dir/appliance/console/index.html"
if [ ! -L /opt/sovereign/current ]; then
  ln -s "releases/$version" /opt/sovereign/current
fi
printf '%s\n' "Sovereign image initialized" > /data/sovereign/proof-ready
