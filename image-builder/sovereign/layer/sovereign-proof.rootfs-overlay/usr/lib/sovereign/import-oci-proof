#!/bin/sh

set -eu

artifact_dir=/usr/lib/sovereign/artifacts
archive=${artifact_dir}/sovereign-oci-proof.oci.tar
image=sovereign/oci-proof:arm64
expected_output='Sovereign ARM64 OCI artifact proof'
state_dir=/data/sovereign
marker=${state_dir}/oci-import-ready
manifest_digest=$(cat "${artifact_dir}/sovereign-oci-proof.manifest-digest")

if [ -f "$marker" ] && docker image inspect "$manifest_digest" >/dev/null 2>&1; then
  docker image tag "$manifest_digest" "$image"
  exit 0
fi

docker load --input "$archive"
docker image inspect "$manifest_digest" >/dev/null
docker image tag "$manifest_digest" "$image"

platform=$(docker image inspect --format '{{.Os}}/{{.Architecture}}' "$image")
test "$platform" = linux/arm64

output=$(docker run --rm --network none --read-only "$image")
test "$output" = "$expected_output"

install -d -m 0755 "$state_dir"
{
  printf 'image=%s\n' "$image"
  printf 'platform=%s\n' "$platform"
  printf 'image_id=%s\n' "$(docker image inspect --format '{{.Id}}' "$image")"
  printf 'archive_sha256=%s\n' "$(awk '{print $1}' "${archive}.sha256")"
  printf 'manifest_digest=%s\n' "$manifest_digest"
} > "${marker}.tmp"
mv "${marker}.tmp" "$marker"
