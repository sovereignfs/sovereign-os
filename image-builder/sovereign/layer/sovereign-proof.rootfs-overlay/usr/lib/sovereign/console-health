#!/usr/bin/python3

import datetime
import json
import os
import pathlib
import socket
import subprocess
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


LISTEN_ADDRESS = os.environ.get("SOVEREIGN_HEALTH_ADDRESS", "127.0.0.1")
LISTEN_PORT = int(os.environ.get("SOVEREIGN_HEALTH_PORT", "8090"))
DATA_PATH = pathlib.Path(os.environ.get("SOVEREIGN_DATA_PATH", "/data"))
STATE_PATH = DATA_PATH / "sovereign"
RELEASE_PATH = pathlib.Path(
    os.environ.get("SOVEREIGN_RELEASE_PATH", "/etc/sovereign-release")
)
DIG_PATH = os.environ.get("SOVEREIGN_DIG_PATH", "/usr/bin/dig")
IP_PATH = os.environ.get("SOVEREIGN_IP_PATH", "/usr/sbin/ip")


def read_key_values(path):
    values = {}
    try:
        for line in pathlib.Path(path).read_text().splitlines():
            key, separator, value = line.partition("=")
            if separator:
                values[key.strip()] = value.strip().strip('"')
    except (OSError, UnicodeError):
        pass
    return values


def marker_check(filename, required):
    values = read_key_values(STATE_PATH / filename)
    healthy = all(values.get(key) == value for key, value in required.items())
    return {
        "status": "healthy" if healthy else "degraded",
        "summary": "Available" if healthy else "Needs attention",
    }


def memory_summary():
    values = {}
    try:
        for line in pathlib.Path("/proc/meminfo").read_text().splitlines():
            key, value = line.split(":", 1)
            values[key] = int(value.strip().split()[0]) * 1024
    except (OSError, UnicodeError, ValueError):
        return None
    total = values.get("MemTotal", 0)
    available = values.get("MemAvailable", 0)
    if not total:
        return None
    return {
        "total_bytes": total,
        "available_bytes": available,
        "used_percent": round((total - available) * 100 / total, 1),
    }


def storage_summary(path):
    try:
        filesystem = os.statvfs(path)
    except OSError:
        return None
    total = filesystem.f_blocks * filesystem.f_frsize
    available = filesystem.f_bavail * filesystem.f_frsize
    if not total:
        return None
    return {
        "total_bytes": total,
        "available_bytes": available,
        "used_percent": round((total - available) * 100 / total, 1),
    }


def temperature_celsius():
    try:
        raw = pathlib.Path("/sys/class/thermal/thermal_zone0/temp").read_text()
        return round(int(raw.strip()) / 1000, 1)
    except (OSError, ValueError):
        return None


def uptime_seconds():
    try:
        return int(float(pathlib.Path("/proc/uptime").read_text().split()[0]))
    except (OSError, ValueError, IndexError):
        return None


def device_model():
    try:
        return pathlib.Path("/proc/device-tree/model").read_text().rstrip("\x00\n")
    except (OSError, UnicodeError):
        return "Sovereign device"


def network_interfaces():
    try:
        completed = subprocess.run(
            [IP_PATH, "-json", "address", "show"],
            check=True,
            capture_output=True,
            text=True,
            timeout=2,
        )
        interfaces = json.loads(completed.stdout)
    except (OSError, subprocess.SubprocessError, json.JSONDecodeError):
        return []

    result = []
    for interface in interfaces:
        name = interface.get("ifname", "")
        if name not in ("eth0", "wlan0"):
            continue
        addresses = [
            address.get("local")
            for address in interface.get("addr_info", [])
            if address.get("family") == "inet" and address.get("local")
        ]
        result.append(
            {
                "name": name,
                "state": interface.get("operstate", "UNKNOWN").lower(),
                "addresses": addresses,
            }
        )
    return result


def dns_check():
    try:
        completed = subprocess.run(
            [
                DIG_PATH,
                "+short",
                "+time=2",
                "+tries=1",
                "@127.0.0.1",
                "example.com",
            ],
            check=True,
            capture_output=True,
            text=True,
            timeout=3,
        )
        healthy = bool(completed.stdout.strip())
    except (OSError, subprocess.SubprocessError):
        healthy = False
    return {
        "status": "healthy" if healthy else "degraded",
        "summary": "Resolving normally" if healthy else "DNS is unavailable",
    }


def tcp_check(port):
    try:
        with socket.create_connection(("127.0.0.1", port), timeout=1):
            return True
    except OSError:
        return False


def collect_health():
    release = read_key_values(RELEASE_PATH)
    local_web_healthy = tcp_check(80)
    checks = {
        "storage": marker_check(
            "update-state/data-expand-ready", {"partition": "3"}
        ),
        "dns": dns_check(),
        "pihole": marker_check(
            "pihole-ready",
            {
                "health": "healthy",
                "dns": "pass",
                "http": "pass",
                "credential": "pass",
            },
        ),
        "local_access": {
            "status": "healthy" if local_web_healthy else "degraded",
            "summary": (
                "Console is reachable"
                if local_web_healthy
                else "Local web access is unavailable"
            ),
        },
    }
    if not tcp_check(8080):
        checks["pihole"] = {
            "status": "degraded",
            "summary": "Pi-hole is unavailable",
        }
    status = (
        "healthy"
        if all(check["status"] == "healthy" for check in checks.values())
        else "degraded"
    )
    return {
        "schema_version": "1",
        "status": status,
        "checked_at": datetime.datetime.now(datetime.timezone.utc)
        .replace(microsecond=0)
        .isoformat()
        .replace("+00:00", "Z"),
        "system": {
            "name": release.get("NAME", "Sovereign OS"),
            "version": release.get("VERSION", "unknown"),
            "model": device_model(),
            "uptime_seconds": uptime_seconds(),
            "memory": memory_summary(),
            "data_storage": storage_summary(DATA_PATH),
            "temperature_celsius": temperature_celsius(),
            "network": network_interfaces(),
        },
        "checks": checks,
    }


class HealthHandler(BaseHTTPRequestHandler):
    server_version = "SovereignHealth/1"
    sys_version = ""

    def do_GET(self):
        if self.path != "/api/v1/health":
            self.send_error(404)
            return
        body = json.dumps(collect_health(), separators=(",", ":")).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-Content-Type-Options", "nosniff")
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format_string, *arguments):
        return


if __name__ == "__main__":
    server = ThreadingHTTPServer((LISTEN_ADDRESS, LISTEN_PORT), HealthHandler)
    server.serve_forever()
