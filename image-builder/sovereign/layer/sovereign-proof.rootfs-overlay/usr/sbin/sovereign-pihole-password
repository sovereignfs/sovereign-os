#!/bin/sh

set -eu

password_file=/data/sovereign/secrets/pihole-admin-password
temporary_file=${password_file}.tmp

if [ "$(id -u)" -ne 0 ]; then
  printf 'Run this command with sudo.\n' >&2
  exit 1
fi

if [ ! -t 0 ]; then
  printf 'An interactive terminal is required.\n' >&2
  exit 1
fi

restore_terminal() {
  stty echo 2>/dev/null || true
  rm -f "$temporary_file"
}
trap restore_terminal EXIT HUP INT TERM

printf 'New Pi-hole password (minimum 12 characters): '
stty -echo
IFS= read -r password
printf '\nConfirm new Pi-hole password: '
IFS= read -r confirmation
stty echo
printf '\n'

if [ "$password" != "$confirmation" ]; then
  printf 'Passwords do not match.\n' >&2
  exit 1
fi

if [ "${#password}" -lt 12 ]; then
  printf 'Password must contain at least 12 characters.\n' >&2
  exit 1
fi

if [ ! -s "$password_file" ]; then
  printf 'The Sovereign Pi-hole password file is missing.\n' >&2
  exit 1
fi

if [ "$(docker inspect --format '{{.State.Running}}' pihole 2>/dev/null || true)" != true ]; then
  printf 'The Pi-hole container is not running.\n' >&2
  exit 1
fi

umask 077
printf '%s\n' "$password" > "$temporary_file"

# Pi-hole stores its effective password in persistent configuration. Update it
# first, then atomically replace the Sovereign secret used for future container
# creation. The password is necessarily passed to Pi-hole's supported CLI but
# is never written to ordinary logs by this command.
docker exec pihole pihole setpassword "$password" >/dev/null
mv "$temporary_file" "$password_file"
chmod 0600 "$password_file"

password=
confirmation=
printf 'Pi-hole administrator password updated.\n'

