import tempfile


POLICY_PATH = pathlib.Path(
    os.environ.get("SOVEREIGN_UPDATE_POLICY", "/etc/sovereign/update-policy.json")
)
RELEASE_PATH = pathlib.Path(
    os.environ.get("SOVEREIGN_RELEASE_PATH", "/etc/sovereign-release")
)
PIHOLE_ENV_OVERRIDE = os.environ.get("SOVEREIGN_PIHOLE_ENV")
DATA_PATH = pathlib.Path(os.environ.get("SOVEREIGN_DATA_PATH", "/data"))
OPENSSL = os.environ.get("SOVEREIGN_OPENSSL", "/usr/bin/openssl")
TAR = os.environ.get("SOVEREIGN_TAR", "/usr/bin/tar")
ZSTD = os.environ.get("SOVEREIGN_ZSTD", "/usr/bin/zstd")
DOCKER = os.environ.get("SOVEREIGN_DOCKER", "/usr/bin/docker")
SYSTEMCTL = os.environ.get("SOVEREIGN_SYSTEMCTL", "/usr/bin/systemctl")
NGINX = os.environ.get("SOVEREIGN_NGINX", "/usr/sbin/nginx")
SHELL = os.environ.get("SOVEREIGN_SHELL", "/bin/sh")
HEALTH_CHECK_OVERRIDE = os.environ.get("SOVEREIGN_UPDATE_HEALTH_CHECK")
UPDATE_ROOT = pathlib.Path(
    os.environ.get("SOVEREIGN_UPDATE_ROOT", str(DATA_PATH / "sovereign/update-state"))
)
STATE_ROOT = pathlib.Path(
    os.environ.get("SOVEREIGN_STATE_ROOT", str(DATA_PATH / "sovereign"))
)
UPDATE_STATUS_PATH = pathlib.Path(
    os.environ.get("SOVEREIGN_UPDATE_STATUS", str(STATE_ROOT / "update-status.json"))
)
RELEASES_ROOT = pathlib.Path(
    os.environ.get("SOVEREIGN_RELEASES_ROOT", "/opt/sovereign")
)

APPLIANCE_FILES = {
    "appliance/bin/console-health": 0o755,
    "appliance/bin/start-pihole": 0o755,
    "appliance/bin/stop-pihole": 0o755,
    "appliance/bin/verify-local-access": 0o755,
    "appliance/bin/verify-update-health": 0o755,
    "appliance/console/assets/console.css": 0o644,
    "appliance/console/assets/console.js": 0o644,
    "appliance/console/index.html": 0o644,
    "appliance/nginx/sovereign.conf": 0o644,
    "appliance/pihole/compose.yaml.in": 0o644,
}
RELEASE_FILES = {
    **APPLIANCE_FILES,
    "pihole-arm64.oci.tar": 0o644,
    "pihole-image.env": 0o644,
    "sovereign-release": 0o644,
}

SAFE_ID = re.compile(r"^[a-z0-9][a-z0-9._-]{0,127}$")
SAFE_KEY_ID = re.compile(r"^[a-z0-9][a-z0-9._-]{0,63}$")
VERSION = re.compile(
    r"^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)"
    r"(?:-([0-9A-Za-z]+(?:[.-][0-9A-Za-z]+)*))?$"
)
SHA256 = re.compile(r"^[0-9a-f]{64}$")
OCI_DIGEST = re.compile(r"^sha256:[0-9a-f]{64}$")
QUALIFICATION_BOUNDARIES = {"backing_up", "activating", "validating"}
QUALIFICATION_EXIT = 75


class UpdateError(Exception):
    def __init__(self, code, message):
        super().__init__(message)
        self.code = code


def fail(condition, code, message):
    if not condition:
        raise UpdateError(code, message)


def validate_qualification_interrupt():
    boundary = os.environ.get("SOVEREIGN_UPDATE_QUALIFICATION_INTERRUPT")
    fail_health = os.environ.get("SOVEREIGN_UPDATE_QUALIFICATION_FAIL_HEALTH")
    if boundary is None and fail_health is None:
        return
    fail(
        os.environ.get("SOVEREIGN_UPDATE_QUALIFICATION") == "1",
        "QUALIFICATION_NOT_ARMED",
        "Qualification interruption requires explicit arming",
    )
    if boundary is not None:
        fail(
            boundary in QUALIFICATION_BOUNDARIES,
            "INVALID_QUALIFICATION_BOUNDARY",
            "Unknown qualification interruption boundary",
        )
    if fail_health is not None:
        fail(
            fail_health == "1",
            "INVALID_QUALIFICATION_HEALTH_FAILURE",
            "Qualification health failure must be set to 1",
        )


def qualification_interrupt(boundary):
    if os.environ.get("SOVEREIGN_UPDATE_QUALIFICATION_INTERRUPT") == boundary:
        # Deliberately bypass normal exception handling and buffered I/O. The
        # preceding transition has already atomically persisted and fsynced its
        # state and event, which is exactly what reboot recovery must inspect.
        os._exit(QUALIFICATION_EXIT)


def qualification_health_failure():
    fail(
        os.environ.get("SOVEREIGN_UPDATE_QUALIFICATION_FAIL_HEALTH") != "1",
        "POSTUPDATE_HEALTH_FAILED",
        "Qualification forced the target health check to fail",
    )


def read_json(path, code="INVALID_JSON"):
    try:
        return json.loads(pathlib.Path(path).read_text(encoding="utf-8"))
    except (OSError, UnicodeError, json.JSONDecodeError) as error:
        raise UpdateError(code, f"Cannot read valid JSON from {path}") from error


def exact_keys(value, required, context):
    fail(isinstance(value, dict), "INVALID_MANIFEST", f"{context} must be an object")
    fail(
        set(value) == set(required),
        "INVALID_MANIFEST",
        f"{context} has missing or unknown fields",
    )


def parse_version(value):
    match = VERSION.fullmatch(value) if isinstance(value, str) else None
    fail(match is not None, "INVALID_VERSION", f"Invalid version: {value!r}")
    core = tuple(int(part) for part in match.group(1, 2, 3))
    prerelease = match.group(4)
    identifiers = None if prerelease is None else prerelease.split(".")
    return core, identifiers


def compare_versions(left, right):
    left_core, left_pre = parse_version(left)
    right_core, right_pre = parse_version(right)
    if left_core != right_core:
        return -1 if left_core < right_core else 1
    if left_pre is None or right_pre is None:
        if left_pre == right_pre:
            return 0
        return 1 if left_pre is None else -1
    for left_id, right_id in zip(left_pre, right_pre):
        if left_id == right_id:
            continue
        left_numeric = left_id.isdigit()
        right_numeric = right_id.isdigit()
        if left_numeric and right_numeric:
            return -1 if int(left_id) < int(right_id) else 1
        if left_numeric != right_numeric:
            return -1 if left_numeric else 1
        return -1 if left_id < right_id else 1
    if len(left_pre) == len(right_pre):
        return 0
    return -1 if len(left_pre) < len(right_pre) else 1


def read_release_version():
    active_release = RELEASES_ROOT / "current/sovereign-release"
    source = active_release if active_release.is_file() else RELEASE_PATH
    try:
        lines = source.read_text(encoding="utf-8").splitlines()
    except (OSError, UnicodeError) as error:
        raise UpdateError("RELEASE_UNAVAILABLE", "Installed release metadata is unavailable") from error
    values = {}
    for line in lines:
        key, separator, value = line.partition("=")
        if separator:
            values[key.strip()] = value.strip().strip('"').strip("'")
    version = values.get("VERSION")
    parse_version(version)
    return version


def installed_pihole_env_path():
    if PIHOLE_ENV_OVERRIDE:
        return pathlib.Path(PIHOLE_ENV_OVERRIDE)
    return RELEASES_ROOT / "current/pihole-image.env"


def health_check_command():
    if HEALTH_CHECK_OVERRIDE:
        return HEALTH_CHECK_OVERRIDE
    return str(RELEASES_ROOT / "current/appliance/bin/verify-update-health")


def read_key_values(path):
    try:
        lines = pathlib.Path(path).read_text(encoding="utf-8").splitlines()
    except (OSError, UnicodeError) as error:
        raise UpdateError("METADATA_UNAVAILABLE", f"Installed metadata is unavailable: {path}") from error
    values = {}
    for line in lines:
        key, separator, value = line.partition("=")
        if separator:
            values[key.strip()] = value.strip().strip('"').strip("'")
    return values


def validate_manifest(manifest):
    top = [
        "schema_version", "release", "compatibility", "artifacts", "components",
        "requirements", "migrations", "rollback", "signing",
    ]
    exact_keys(manifest, top, "manifest")
    fail(manifest["schema_version"] == 1, "UNSUPPORTED_SCHEMA", "Only manifest schema 1 is supported")

    release = manifest["release"]
    exact_keys(release, ["id", "version", "published_at", "channel", "notes_url"], "release")
    fail(isinstance(release["id"], str) and SAFE_ID.fullmatch(release["id"]), "INVALID_MANIFEST", "Invalid release id")
    parse_version(release["version"])
    fail(release["channel"] in ("preview", "stable"), "INVALID_MANIFEST", "Invalid channel")
    fail(isinstance(release["published_at"], str) and release["published_at"].endswith("Z"), "INVALID_MANIFEST", "Invalid publication time")
    fail(isinstance(release["notes_url"], str) and release["notes_url"].startswith("https://"), "INVALID_MANIFEST", "Release notes must use HTTPS")

    compatibility = manifest["compatibility"]
    exact_keys(compatibility, ["devices", "source_versions", "allow_downgrade"], "compatibility")
    fail(isinstance(compatibility["devices"], list) and compatibility["devices"], "INVALID_MANIFEST", "Compatible devices are required")
    fail(all(device == "rpi5-arm64" for device in compatibility["devices"]), "INVALID_MANIFEST", "Unknown device compatibility value")
    fail(compatibility["allow_downgrade"] is False, "INVALID_MANIFEST", "Downgrades cannot be enabled by a manifest")
    source = compatibility["source_versions"]
    exact_keys(source, ["minimum", "maximum_exclusive"], "source_versions")
    parse_version(source["minimum"])
    parse_version(source["maximum_exclusive"])

    artifacts = manifest["artifacts"]
    fail(isinstance(artifacts, list) and len(artifacts) == 1, "INVALID_MANIFEST", "Exactly one update bundle is required")
    artifact = artifacts[0]
    exact_keys(artifact, ["role", "url", "size", "sha256", "media_type"], "artifact")
    fail(artifact["role"] == "update_bundle", "INVALID_MANIFEST", "Invalid artifact role")
    fail(isinstance(artifact["url"], str) and artifact["url"].startswith("https://"), "INVALID_MANIFEST", "Artifact URL must use HTTPS")
    fail(isinstance(artifact["size"], int) and artifact["size"] > 0, "INVALID_MANIFEST", "Invalid artifact size")
    fail(isinstance(artifact["sha256"], str) and SHA256.fullmatch(artifact["sha256"]), "INVALID_MANIFEST", "Invalid artifact digest")
    fail(artifact["media_type"] == "application/vnd.sovereign.update.v1+tar+zstd", "INVALID_MANIFEST", "Invalid artifact media type")

    components = manifest["components"]
    exact_keys(components, ["appliance", "image_base", "pihole"], "components")
    exact_keys(components["appliance"], ["version"], "appliance component")
    exact_keys(components["image_base"], ["version"], "image component")
    parse_version(components["appliance"]["version"])
    parse_version(components["image_base"]["version"])
    pihole = components["pihole"]
    exact_keys(pihole, ["version", "repository", "digest"], "Pi-hole component")
    fail(isinstance(pihole["version"], str) and pihole["version"], "INVALID_MANIFEST", "Pi-hole version is required")
    fail(isinstance(pihole["repository"], str) and pihole["repository"], "INVALID_MANIFEST", "Pi-hole repository is required")
    fail(isinstance(pihole["digest"], str) and OCI_DIGEST.fullmatch(pihole["digest"]), "INVALID_MANIFEST", "Invalid Pi-hole digest")

    requirements = manifest["requirements"]
    exact_keys(requirements, ["free_bytes", "reboot"], "requirements")
    fail(isinstance(requirements["free_bytes"], int) and requirements["free_bytes"] > 0, "INVALID_MANIFEST", "Invalid storage requirement")
    fail(type(requirements["reboot"]) is bool, "INVALID_MANIFEST", "Invalid reboot requirement")
    fail(isinstance(manifest["migrations"], list), "INVALID_MANIFEST", "Migrations must be a list")
    for migration in manifest["migrations"]:
        exact_keys(migration, ["id", "from_schema", "to_schema", "reversible"], "migration")
        fail(isinstance(migration["id"], str) and SAFE_ID.fullmatch(migration["id"]), "INVALID_MANIFEST", "Invalid migration id")
        fail(isinstance(migration["from_schema"], int) and migration["from_schema"] >= 0, "INVALID_MANIFEST", "Invalid source schema")
        fail(isinstance(migration["to_schema"], int) and migration["to_schema"] >= 1, "INVALID_MANIFEST", "Invalid target schema")
        fail(type(migration["reversible"]) is bool, "INVALID_MANIFEST", "Invalid migration reversibility")

    rollback = manifest["rollback"]
    exact_keys(rollback, ["supported", "requires_data_restore", "limitations"], "rollback")
    fail(type(rollback["supported"]) is bool and type(rollback["requires_data_restore"]) is bool, "INVALID_MANIFEST", "Invalid rollback flags")
    fail(isinstance(rollback["limitations"], list) and all(isinstance(item, str) and item for item in rollback["limitations"]), "INVALID_MANIFEST", "Invalid rollback limitations")

    signing = manifest["signing"]
    exact_keys(signing, ["algorithm", "key_id"], "signing")
    fail(signing["algorithm"] == "Ed25519", "INVALID_MANIFEST", "Only Ed25519 is supported")
    fail(isinstance(signing["key_id"], str) and SAFE_KEY_ID.fullmatch(signing["key_id"]), "INVALID_MANIFEST", "Invalid signing key id")


def load_trusted_key(policy, key_id, channel):
    trust_store = pathlib.Path(policy["trust_store"])
    metadata = read_json(trust_store / f"{key_id}.json", "UNKNOWN_SIGNING_KEY")
    exact_keys(metadata, ["schema_version", "key_id", "algorithm", "channels", "revoked"], "trusted key")
    fail(metadata["schema_version"] == 1 and metadata["key_id"] == key_id, "UNTRUSTED_SIGNING_KEY", "Signing-key metadata does not match")
    fail(metadata["algorithm"] == "Ed25519", "UNTRUSTED_SIGNING_KEY", "Signing key has an unsupported algorithm")
    fail(metadata["revoked"] is False, "REVOKED_SIGNING_KEY", "The signing key is revoked")
    fail(channel in metadata["channels"], "WRONG_KEY_CHANNEL", "The signing key is not trusted for this channel")
    public_key = trust_store / f"{key_id}.pem"
    fail(public_key.is_file(), "UNKNOWN_SIGNING_KEY", "Trusted public key is missing")
    return public_key


def verify_signature(manifest_path, signature_path, public_key):
    try:
        encoded = pathlib.Path(signature_path).read_text(encoding="ascii").strip()
        signature = base64.b64decode(encoded, validate=True)
    except (OSError, UnicodeError, binascii.Error) as error:
        raise UpdateError("INVALID_SIGNATURE", "Detached signature is not valid base64") from error
    fail(len(signature) == 64, "INVALID_SIGNATURE", "Ed25519 signature must be 64 bytes")
    descriptor, temporary_name = tempfile.mkstemp(prefix="sovereign-signature-")
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "wb") as temporary:
            temporary.write(signature)
            temporary.flush()
            os.fsync(temporary.fileno())
        completed = subprocess.run(
            [OPENSSL, "pkeyutl", "-verify", "-pubin", "-inkey", str(public_key), "-rawin", "-in", str(manifest_path), "-sigfile", temporary_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=10,
            check=False,
        )
    except (OSError, subprocess.SubprocessError) as error:
        raise UpdateError("SIGNATURE_TOOL_FAILED", "Signature verification could not run") from error
    finally:
        try:
            os.unlink(temporary_name)
        except OSError:
            pass
    fail(completed.returncode == 0, "SIGNATURE_MISMATCH", "Manifest signature verification failed")


def verify_policy(manifest, policy):
    exact_keys(policy, ["schema_version", "channel", "device", "trust_store"], "update policy")
    fail(policy["schema_version"] == 1, "INVALID_POLICY", "Unsupported update policy")
    release = manifest["release"]
    compatibility = manifest["compatibility"]
    fail(release["channel"] == policy["channel"], "WRONG_CHANNEL", "Release channel does not match device policy")
    fail(policy["device"] in compatibility["devices"], "INCOMPATIBLE_DEVICE", "Release does not support this device")
    current = read_release_version()
    bounds = compatibility["source_versions"]
    fail(compare_versions(current, bounds["minimum"]) >= 0, "UNSUPPORTED_SOURCE", "Installed version is below the supported range")
    fail(compare_versions(current, bounds["maximum_exclusive"]) < 0, "UNSUPPORTED_SOURCE", "Installed version is above the supported range")
    fail(compare_versions(release["version"], current) > 0, "DOWNGRADE_REJECTED", "Target version must be newer than the installed version")
    fail(compare_versions(components_version(manifest), release["version"]) == 0, "VERSION_MISMATCH", "Appliance and release versions differ")
    try:
        free_bytes = shutil.disk_usage(DATA_PATH).free
    except OSError as error:
        raise UpdateError("STORAGE_UNAVAILABLE", "Persistent storage is unavailable") from error
    fail(free_bytes >= manifest["requirements"]["free_bytes"], "INSUFFICIENT_STORAGE", "Not enough free persistent storage")
    return current


def components_version(manifest):
    return manifest["components"]["appliance"]["version"]


def verify_artifact(path, artifact):
    candidate = pathlib.Path(path)
    try:
        stat = candidate.stat()
    except OSError as error:
        raise UpdateError("ARTIFACT_UNAVAILABLE", "Update artifact cannot be read") from error
    fail(stat.st_size == artifact["size"], "ARTIFACT_SIZE_MISMATCH", "Update artifact size does not match")
    digest = hashlib.sha256()
    try:
        with candidate.open("rb") as stream:
            for chunk in iter(lambda: stream.read(1024 * 1024), b""):
                digest.update(chunk)
    except OSError as error:
        raise UpdateError("ARTIFACT_UNAVAILABLE", "Update artifact cannot be read") from error
    fail(digest.hexdigest() == artifact["sha256"], "ARTIFACT_DIGEST_MISMATCH", "Update artifact digest does not match")


def inspect_update(args, emit=True):
    policy = read_json(POLICY_PATH, "INVALID_POLICY")
    manifest_path = pathlib.Path(args.manifest)
    try:
        manifest_bytes = manifest_path.read_bytes()
        manifest = json.loads(manifest_bytes)
    except (OSError, UnicodeError, json.JSONDecodeError) as error:
        raise UpdateError("INVALID_MANIFEST", "Manifest is not valid UTF-8 JSON") from error
    fail(manifest_bytes.endswith(b"\n"), "INVALID_MANIFEST_BYTES", "Signed manifest must end with a newline")
    signing = manifest.get("signing") if isinstance(manifest, dict) else None
    fail(isinstance(signing, dict), "INVALID_MANIFEST", "Signing metadata is missing")
    key_id = signing.get("key_id")
    channel = manifest.get("release", {}).get("channel") if isinstance(manifest.get("release"), dict) else None
    fail(isinstance(key_id, str) and SAFE_KEY_ID.fullmatch(key_id), "INVALID_MANIFEST", "Invalid signing key id")
    fail(channel in ("preview", "stable"), "INVALID_MANIFEST", "Invalid release channel")
    public_key = load_trusted_key(policy, key_id, channel)
    verify_signature(manifest_path, args.signature, public_key)
    validate_manifest(manifest)
    current = verify_policy(manifest, policy)
    if args.artifact:
        verify_artifact(args.artifact, manifest["artifacts"][0])
    result = {
        "status": "verified",
        "source_version": current,
        "target_version": manifest["release"]["version"],
        "channel": manifest["release"]["channel"],
        "key_id": key_id,
        "artifact_verified": bool(args.artifact),
        "reboot_required": manifest["requirements"]["reboot"],
        "rollback_supported": manifest["rollback"]["supported"],
    }
    if emit:
        print(json.dumps(result, sort_keys=True))
    return manifest, result


def timestamp():
    return (
        datetime.datetime.now(datetime.timezone.utc)
        .replace(microsecond=0)
        .isoformat()
        .replace("+00:00", "Z")
    )


def sync_directory(path):
    descriptor = os.open(path, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0))
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def atomic_json(path, value, mode=0o600):
    path = pathlib.Path(path)
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    temporary = path.with_name(f".{path.name}.{secrets.token_hex(4)}.tmp")
    descriptor = os.open(temporary, os.O_WRONLY | os.O_CREAT | os.O_EXCL, mode)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as stream:
            json.dump(value, stream, sort_keys=True, separators=(",", ":"))
            stream.write("\n")
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
        os.chmod(path, mode)
        sync_directory(path.parent)
    finally:
        try:
            temporary.unlink()
        except OSError:
            pass


@contextlib.contextmanager
def update_lock():
    UPDATE_ROOT.mkdir(parents=True, exist_ok=True, mode=0o700)
    lock_path = UPDATE_ROOT / "update.lock"
    descriptor = os.open(lock_path, os.O_RDWR | os.O_CREAT, 0o600)
    try:
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError as error:
            raise UpdateError("UPDATE_BUSY", "Another update operation is running") from error
        yield
    finally:
        os.close(descriptor)


def transaction_path(transaction_id):
    fail(bool(SAFE_ID.fullmatch(transaction_id)), "INVALID_TRANSACTION", "Invalid transaction id")
    return UPDATE_ROOT / "transactions" / transaction_id


def append_event(directory, previous, snapshot, reason):
    event = {
        "transaction_id": snapshot["transaction_id"],
        "sequence": snapshot["sequence"],
        "previous_state": previous,
        "next_state": snapshot["state"],
        "timestamp": snapshot["updated_at"],
        "reason": reason,
    }
    path = directory / "events.jsonl"
    descriptor = os.open(path, os.O_WRONLY | os.O_APPEND | os.O_CREAT, 0o600)
    with os.fdopen(descriptor, "a", encoding="utf-8") as stream:
        stream.write(json.dumps(event, sort_keys=True, separators=(",", ":")) + "\n")
        stream.flush()
        os.fsync(stream.fileno())
    sync_directory(directory)


def create_transaction(source_version, target_version):
    now = timestamp()
    compact = now.replace("-", "").replace(":", "").lower()
    transaction_id = f"update-{compact}-{secrets.token_hex(4)}"
    directory = transaction_path(transaction_id)
    directory.mkdir(parents=True, mode=0o700)
    snapshot = {
        "schema_version": 1,
        "transaction_id": transaction_id,
        "sequence": 0,
        "state": "available",
        "source_version": source_version,
        "target_version": target_version,
        "created_at": now,
        "updated_at": now,
        "backup_id": None,
        "failure": None,
        "recovery_action": "resume",
    }
    atomic_json(directory / "state.json", snapshot)
    append_event(directory, None, snapshot, "MANIFEST_ACCEPTED")
    publish_update_status(snapshot)
    return snapshot


ALLOWED_TRANSITIONS = {
    "available": {"downloading", "recovery_required"},
    "downloading": {"verified", "recovery_required"},
    "verified": {"backing_up", "recovery_required"},
    "backing_up": {"backed_up", "recovery_required"},
    "backed_up": {"staged", "recovery_required"},
    "staged": {"activating", "recovery_required"},
    "activating": {"validating", "rolling_back", "recovery_required"},
    "validating": {"committed", "rolling_back", "recovery_required"},
    "rolling_back": {"rolled_back", "recovery_required"},
    "rolled_back": {"discarded"},
    "recovery_required": {"discarded"},
}


def transition(snapshot, next_state, reason, **changes):
    fail(next_state in ALLOWED_TRANSITIONS.get(snapshot["state"], set()), "INVALID_TRANSITION", f"Cannot move from {snapshot['state']} to {next_state}")
    previous = snapshot["state"]
    snapshot = dict(snapshot)
    snapshot.update(changes)
    snapshot["state"] = next_state
    snapshot["sequence"] += 1
    snapshot["updated_at"] = timestamp()
    directory = transaction_path(snapshot["transaction_id"])
    atomic_json(directory / "state.json", snapshot)
    append_event(directory, previous, snapshot, reason)
    publish_update_status(snapshot)
    return snapshot


def publish_update_status(snapshot):
    atomic_json(
        UPDATE_STATUS_PATH,
        {
            "schema_version": 1,
            "state": snapshot["state"],
            "target_version": snapshot["target_version"],
            "updated_at": snapshot["updated_at"],
        },
        mode=0o644,
    )


def load_transaction(transaction_id, required_state=None):
    snapshot = read_json(
        transaction_path(transaction_id) / "state.json", "INVALID_TRANSACTION"
    )
    fail(
        snapshot.get("transaction_id") == transaction_id,
        "INVALID_TRANSACTION",
        "Transaction identity does not match",
    )
    if required_state:
        fail(
            snapshot.get("state") == required_state,
            "INVALID_TRANSACTION_STATE",
            f"Transaction must be {required_state}",
        )
    return snapshot


def copy_verified(source, destination, expected_size=None, expected_digest=None):
    source = pathlib.Path(source)
    destination = pathlib.Path(destination)
    digest = hashlib.sha256()
    size = 0
    descriptor = os.open(destination, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
    try:
        with source.open("rb") as input_stream, os.fdopen(descriptor, "wb") as output_stream:
            for chunk in iter(lambda: input_stream.read(1024 * 1024), b""):
                output_stream.write(chunk)
                digest.update(chunk)
                size += len(chunk)
            output_stream.flush()
            os.fsync(output_stream.fileno())
    except OSError as error:
        try:
            destination.unlink()
        except OSError:
            pass
        raise UpdateError("STAGING_FAILED", "Could not stage update input") from error
    if expected_size is not None:
        fail(size == expected_size, "ARTIFACT_SIZE_MISMATCH", "Staged artifact size does not match")
    if expected_digest is not None:
        fail(digest.hexdigest() == expected_digest, "ARTIFACT_DIGEST_MISMATCH", "Staged artifact digest does not match")
    return size, digest.hexdigest()


def prepare_update(args):
    fail(args.artifact is not None, "ARTIFACT_REQUIRED", "Preparing an update requires the local bundle")
    with update_lock():
        manifest, result = inspect_update(args, emit=False)
        snapshot = create_transaction(result["source_version"], result["target_version"])
        directory = transaction_path(snapshot["transaction_id"])
        staging = directory / "staging"
        staging.mkdir(mode=0o700)
        snapshot = transition(snapshot, "downloading", "LOCAL_STAGING_STARTED")
        copy_verified(args.manifest, staging / "release-manifest.json")
        copy_verified(args.signature, staging / "release-manifest.sig")
        artifact = manifest["artifacts"][0]
        copy_verified(args.artifact, staging / "update-bundle.tar.zst", artifact["size"], artifact["sha256"])
        sync_directory(staging)
        staged_args = argparse.Namespace(
            manifest=staging / "release-manifest.json",
            signature=staging / "release-manifest.sig",
            artifact=staging / "update-bundle.tar.zst",
        )
        inspect_update(staged_args, emit=False)
        snapshot = transition(snapshot, "verified", "STAGED_INPUTS_VERIFIED")
        print(json.dumps({"status": "verified", "transaction_id": snapshot["transaction_id"], "target_version": snapshot["target_version"]}, sort_keys=True))


def run_checked(command, code, message, timeout=120):
    try:
        subprocess.run(
            command,
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=timeout,
        )
    except (OSError, subprocess.SubprocessError) as error:
        raise UpdateError(code, message) from error


def archive_directory(source, destination):
    source = pathlib.Path(source)
    fail(source.is_dir(), "BACKUP_SOURCE_MISSING", f"Backup source is missing: {source.name}")
    run_checked(
        [
            TAR,
            "--create",
            "--zstd",
            "--file",
            str(destination),
            "--numeric-owner",
            "--owner=0",
            "--group=0",
            "--no-acls",
            "--no-xattrs",
            "--directory",
            str(source.parent),
            source.name,
        ],
        "BACKUP_ARCHIVE_FAILED",
        f"Could not archive {source.name}",
        timeout=600,
    )
    os.chmod(destination, 0o600)
    try:
        listing = subprocess.run(
            [TAR, "--list", "--zstd", "--file", str(destination)],
            check=True,
            capture_output=True,
            text=True,
            timeout=120,
        ).stdout.splitlines()
    except (OSError, subprocess.SubprocessError) as error:
        raise UpdateError("BACKUP_ARCHIVE_INVALID", f"Could not validate {destination.name}") from error
    fail(0 < len(listing) <= 100000, "BACKUP_ARCHIVE_INVALID", "Backup archive has an invalid entry count")
    for entry in listing:
        path = pathlib.PurePosixPath(entry.rstrip("/"))
        fail(not path.is_absolute() and ".." not in path.parts, "BACKUP_ARCHIVE_UNSAFE", "Backup archive contains an unsafe path")
        fail(path.parts and path.parts[0] == source.name, "BACKUP_ARCHIVE_UNSAFE", "Backup archive escaped its role prefix")
    digest = hashlib.sha256()
    with destination.open("rb") as stream:
        for chunk in iter(lambda: stream.read(1024 * 1024), b""):
            digest.update(chunk)
    return {
        "size": destination.stat().st_size,
        "sha256": digest.hexdigest(),
    }


def release_pointer_source(directory, snapshot, manifest):
    source = directory / "release-pointer"
    source.mkdir(mode=0o700)
    pointer = {
        "source_version": snapshot["source_version"],
        "target_version": snapshot["target_version"],
        "pihole_digest": manifest["components"]["pihole"]["digest"],
        "active_release": None,
    }
    current = RELEASES_ROOT / "current"
    if current.is_symlink():
        pointer["active_release"] = os.readlink(current)
    atomic_json(source / "release-pointer.json", pointer)
    return source


def create_backup(args):
    fail(
        os.geteuid() == 0 or os.environ.get("SOVEREIGN_UPDATE_TEST_MODE") == "1",
        "ROOT_REQUIRED",
        "Backup requires administrator privileges",
    )
    with update_lock():
        snapshot = load_transaction(args.transaction, "verified")
        directory = transaction_path(args.transaction)
        manifest = read_json(directory / "staging/release-manifest.json")
        installed_pihole = read_key_values(installed_pihole_env_path())
        source_pihole_digest = installed_pihole.get("PIHOLE_IMAGE_DIGEST")
        fail(
            isinstance(source_pihole_digest, str)
            and OCI_DIGEST.fullmatch(source_pihole_digest),
            "METADATA_UNAVAILABLE",
            "Installed Pi-hole digest is unavailable",
        )
        snapshot = transition(snapshot, "backing_up", "BACKUP_STARTED")
        qualification_interrupt("backing_up")
        now = timestamp()
        compact = now.replace("-", "").replace(":", "").lower()
        backup_id = f"backup-{compact}-{secrets.token_hex(4)}"
        backup = STATE_ROOT / "backups" / backup_id
        backup.mkdir(parents=True, mode=0o700)
        stopped = False
        try:
            run_checked(
                [SYSTEMCTL, "stop", "sovereign-pihole.service"],
                "SERVICE_STOP_FAILED",
                "Pi-hole could not be stopped for backup",
            )
            stopped = True
            release_source = release_pointer_source(directory, snapshot, manifest)
            sources = [
                ("pihole_state", STATE_ROOT / "apps/pihole/etc-pihole", "pihole-state.tar.zst"),
                ("sovereign_configuration", STATE_ROOT / "configuration", "sovereign-configuration.tar.zst"),
                ("secrets", STATE_ROOT / "secrets", "secrets.tar.zst"),
                ("release_pointer", release_source, "release-pointer.tar.zst"),
            ]
            artifacts = []
            for role, source, filename in sources:
                details = archive_directory(source, backup / filename)
                artifacts.append({"role": role, "file": filename, **details})
            run_checked(
                [SYSTEMCTL, "start", "sovereign-pihole.service"],
                "SERVICE_RESTART_FAILED",
                "Pi-hole could not be restarted after backup",
            )
            stopped = False
            run_checked(
                [health_check_command()],
                "PREUPDATE_HEALTH_FAILED",
                "Pi-hole did not recover after backup",
            )
            backup_manifest = {
                "schema_version": 1,
                "backup_id": backup_id,
                "transaction_id": args.transaction,
                "created_at": now,
                "source": {
                    "appliance_version": snapshot["source_version"],
                    "pihole_digest": source_pihole_digest,
                    "data_schema": 1,
                },
                "consistency": {
                    "method": "quiesced",
                    "services_stopped": ["sovereign-pihole"],
                    "restarted_and_healthy": True,
                },
                "artifacts": artifacts,
            }
            atomic_json(backup / "backup-manifest.json", backup_manifest)
            sync_directory(backup)
            snapshot = transition(
                snapshot,
                "backed_up",
                "BACKUP_VERIFIED",
                backup_id=backup_id,
            )
            print(json.dumps({"status": "backed_up", "transaction_id": args.transaction, "backup_id": backup_id}, sort_keys=True))
        except UpdateError as error:
            if stopped:
                try:
                    run_checked(
                        [SYSTEMCTL, "start", "sovereign-pihole.service"],
                        "SERVICE_RESTART_FAILED",
                        "Pi-hole could not be restarted after backup failure",
                    )
                except UpdateError:
                    pass
            transition(
                snapshot,
                "recovery_required",
                error.code,
                failure={"code": error.code, "message": str(error), "retryable": False},
                recovery_action="manual",
            )
            raise


def validate_bundle_manifest(value, target_version):
    exact_keys(value, ["schema_version", "release_version", "files"], "bundle manifest")
    fail(value["schema_version"] == 1, "INVALID_BUNDLE", "Unsupported bundle schema")
    fail(value["release_version"] == target_version, "INVALID_BUNDLE", "Bundle release version does not match")
    fail(isinstance(value["files"], list) and value["files"], "INVALID_BUNDLE", "Bundle file list is empty")
    seen = set()
    for item in value["files"]:
        exact_keys(item, ["path", "size", "sha256", "mode"], "bundle file")
        path = pathlib.PurePosixPath(item["path"])
        fail(not path.is_absolute() and path.parts[0] == "release" and ".." not in path.parts, "UNSAFE_BUNDLE", "Bundle file path is unsafe")
        fail(item["path"] not in seen, "INVALID_BUNDLE", "Bundle contains duplicate file metadata")
        seen.add(item["path"])
        fail(isinstance(item["size"], int) and item["size"] >= 0, "INVALID_BUNDLE", "Invalid bundle file size")
        fail(isinstance(item["sha256"], str) and SHA256.fullmatch(item["sha256"]), "INVALID_BUNDLE", "Invalid bundle file digest")
        fail(item["mode"] in (0o644, 0o755), "UNSAFE_BUNDLE", "Unsafe bundle file mode")
    return {item["path"]: item for item in value["files"]}


def extract_bundle(bundle, destination, target_version):
    transaction_directory = destination.parent
    tar_path = transaction_directory / "update-bundle.tar"
    run_checked(
        [ZSTD, "--decompress", "--quiet", "--force", "--output-dir-flat", str(transaction_directory), str(bundle)],
        "BUNDLE_DECOMPRESSION_FAILED",
        "Update bundle could not be decompressed",
        timeout=600,
    )
    # zstd derives the output by removing .zst from update-bundle.tar.zst.
    fail(tar_path.is_file(), "BUNDLE_DECOMPRESSION_FAILED", "Decompressed update bundle is missing")
    try:
        with tarfile.open(tar_path, "r:") as archive:
            members = archive.getmembers()
            fail(0 < len(members) <= 100000, "INVALID_BUNDLE", "Bundle has an invalid entry count")
            names = [member.name for member in members]
            fail(len(names) == len(set(names)), "INVALID_BUNDLE", "Bundle contains duplicate archive names")
            for member in members:
                path = pathlib.PurePosixPath(member.name)
                fail(not path.is_absolute() and ".." not in path.parts, "UNSAFE_BUNDLE", "Bundle archive path is unsafe")
                fail(member.isfile(), "UNSAFE_BUNDLE", "Only regular files are allowed in update bundles")
            manifest_name = "sovereign-update-v1/bundle-manifest.json"
            fail(manifest_name in names, "INVALID_BUNDLE", "Bundle manifest is missing")
            bundle_manifest = json.load(archive.extractfile(manifest_name))
            declared = validate_bundle_manifest(bundle_manifest, target_version)
            expected = {manifest_name} | {
                f"sovereign-update-v1/{name}" for name in declared
            }
            fail(set(names) == expected, "INVALID_BUNDLE", "Bundle has unlisted or missing files")
            destination.mkdir(parents=True, mode=0o755)
            for relative, details in declared.items():
                member = archive.getmember(f"sovereign-update-v1/{relative}")
                output = destination.joinpath(*pathlib.PurePosixPath(relative).parts[1:])
                output.parent.mkdir(parents=True, exist_ok=True, mode=0o755)
                digest = hashlib.sha256()
                size = 0
                descriptor = os.open(output, os.O_WRONLY | os.O_CREAT | os.O_EXCL, details["mode"])
                with archive.extractfile(member) as source, os.fdopen(descriptor, "wb") as target:
                    for chunk in iter(lambda: source.read(1024 * 1024), b""):
                        target.write(chunk)
                        digest.update(chunk)
                        size += len(chunk)
                    target.flush()
                    os.fsync(target.fileno())
                fail(size == details["size"] and digest.hexdigest() == details["sha256"], "BUNDLE_FILE_MISMATCH", f"Bundle file failed verification: {relative}")
                os.chmod(output, details["mode"])
    except (OSError, tarfile.TarError, json.JSONDecodeError, KeyError) as error:
        raise UpdateError("INVALID_BUNDLE", "Update bundle structure is invalid") from error
    finally:
        try:
            tar_path.unlink()
        except OSError:
            pass


def validate_release_payload(release, manifest):
    actual = {
        path.relative_to(release).as_posix(): stat.S_IMODE(path.stat().st_mode)
        for path in release.rglob("*")
        if path.is_file()
    }
    fail(
        set(actual) == set(RELEASE_FILES),
        "INCOMPLETE_RELEASE",
        "Release payload has missing or unknown files",
    )
    fail(
        actual == RELEASE_FILES,
        "UNSAFE_RELEASE_MODE",
        "Release payload has an invalid file mode",
    )
    identity = read_key_values(release / "sovereign-release")
    pihole = read_key_values(release / "pihole-image.env")
    fail(identity.get("VERSION") == manifest["release"]["version"], "VERSION_MISMATCH", "Release identity does not match")
    fail(identity.get("CHANNEL") == manifest["release"]["channel"], "WRONG_CHANNEL", "Release identity channel does not match")
    target = manifest["components"]["pihole"]
    fail(pihole.get("PIHOLE_IMAGE_REPOSITORY") == target["repository"], "COMPONENT_MISMATCH", "Pi-hole repository does not match")
    fail(pihole.get("PIHOLE_IMAGE_DIGEST") == target["digest"], "COMPONENT_MISMATCH", "Pi-hole digest does not match")
    fail(pihole.get("PIHOLE_IMAGE_PLATFORM") == "linux/arm64", "COMPONENT_MISMATCH", "Pi-hole platform does not match")
    validate_appliance_configuration(release, target)


def validate_appliance_configuration(release, pihole):
    appliance = release / "appliance"
    for script in sorted((appliance / "bin").iterdir()):
        if script.name == "console-health":
            try:
                compile(
                    script.read_text(encoding="utf-8"),
                    str(script),
                    "exec",
                )
            except (OSError, UnicodeError, SyntaxError) as error:
                raise UpdateError(
                    "INVALID_APPLIANCE_SCRIPT",
                    "Console health service has invalid Python syntax",
                ) from error
        else:
            run_checked(
                [SHELL, "-n", str(script)],
                "INVALID_APPLIANCE_SCRIPT",
                f"Appliance script has invalid shell syntax: {script.name}",
            )

    html = appliance / "console/index.html"
    try:
        console = "\n".join(
            path.read_text(encoding="utf-8")
            for path in (
                html,
                appliance / "console/assets/console.css",
                appliance / "console/assets/console.js",
            )
        ).lower()
    except (OSError, UnicodeError) as error:
        raise UpdateError(
            "INVALID_CONSOLE_ASSETS", "Console assets are not valid UTF-8"
        ) from error
    fail(
        'href="/console/assets/console.css"' in console
        and 'src="/console/assets/console.js"' in console,
        "INVALID_CONSOLE_ASSETS",
        "Console does not reference its packaged assets",
    )
    fail(
        "http://" not in console and "https://" not in console,
        "EXTERNAL_CONSOLE_ASSET",
        "Console assets must not load external resources",
    )
    fail(
        f"release {manifest_version(release)}" in console
        and "@sovereign_release_version@" not in console,
        "INVALID_CONSOLE_ASSETS",
        "Console release identity does not match the target release",
    )

    image_reference = (
        f"{pihole['repository'].removeprefix('docker.io/')}@{pihole['digest']}"
    )
    with tempfile.TemporaryDirectory(
        prefix="appliance-validation-", dir=release.parent
    ) as temporary_directory:
        temporary = pathlib.Path(temporary_directory)
        compose = temporary / "compose.yaml"
        try:
            template = (appliance / "pihole/compose.yaml.in").read_text(
                encoding="utf-8"
            )
            fail(
                template.count("@PIHOLE_IMAGE_REFERENCE@") == 1,
                "INVALID_COMPOSE_TEMPLATE",
                "Pi-hole Compose template has an invalid image placeholder",
            )
            compose.write_text(
                template.replace("@PIHOLE_IMAGE_REFERENCE@", image_reference),
                encoding="utf-8",
            )
        except (OSError, UnicodeError) as error:
            raise UpdateError(
                "INVALID_COMPOSE_TEMPLATE",
                "Pi-hole Compose template could not be rendered",
            ) from error
        run_checked(
            [DOCKER, "compose", "--file", str(compose), "config", "--quiet"],
            "INVALID_COMPOSE_TEMPLATE",
            "Pi-hole Compose template failed validation",
        )

        nginx_include = str(appliance / "nginx/sovereign.conf").replace(
            "\\", "\\\\"
        ).replace('"', '\\"')
        nginx_config = temporary / "nginx.conf"
        nginx_config.write_text(
            f'pid "{temporary / "nginx.pid"}";\n'
            "error_log stderr;\n"
            "events {}\n"
            "http {\n"
            "  access_log off;\n"
            "  include /etc/nginx/mime.types;\n"
            f'  include "{nginx_include}";\n'
            "}\n",
            encoding="utf-8",
        )
        run_checked(
            [NGINX, "-t", "-c", str(nginx_config), "-p", "/"],
            "INVALID_NGINX_CONFIGURATION",
            "Sovereign Nginx configuration failed validation",
        )


def manifest_version(release):
    return read_key_values(release / "sovereign-release").get("VERSION", "")


def stage_release(args):
    fail(os.geteuid() == 0 or os.environ.get("SOVEREIGN_UPDATE_TEST_MODE") == "1", "ROOT_REQUIRED", "Staging requires administrator privileges")
    with update_lock():
        snapshot = load_transaction(args.transaction, "backed_up")
        directory = transaction_path(args.transaction)
        manifest = read_json(directory / "staging/release-manifest.json")
        fail(not manifest["migrations"], "MIGRATION_UNSUPPORTED", "Data migrations are not supported by this updater version")
        fail(manifest["rollback"]["supported"], "ROLLBACK_UNSUPPORTED", "This updater requires a rollback-capable release")
        releases = RELEASES_ROOT / "releases"
        releases.mkdir(parents=True, exist_ok=True, mode=0o755)
        final_release = releases / snapshot["target_version"]
        fail(not final_release.exists(), "RELEASE_EXISTS", "Target release already exists")
        candidate = directory / "release-candidate"
        fail(not candidate.exists(), "STAGING_EXISTS", "Candidate release staging already exists")
        install_candidate = releases / f".{snapshot['target_version']}.{args.transaction}.tmp"
        try:
            extract_bundle(directory / "staging/update-bundle.tar.zst", candidate, snapshot["target_version"])
            validate_release_payload(candidate, manifest)
            install_candidate.mkdir(mode=0o755)
            for source in sorted(candidate.rglob("*")):
                relative = source.relative_to(candidate)
                if relative.as_posix() == "pihole-arm64.oci.tar":
                    continue
                destination = install_candidate / relative
                if source.is_dir():
                    destination.mkdir(exist_ok=True, mode=0o755)
                else:
                    destination.parent.mkdir(parents=True, exist_ok=True, mode=0o755)
                    shutil.copyfile(source, destination)
                    os.chmod(destination, source.stat().st_mode & 0o777)
            sync_directory(install_candidate)
            os.replace(install_candidate, final_release)
            sync_directory(releases)
            snapshot = transition(snapshot, "staged", "RELEASE_STAGED")
            print(json.dumps({"status": "staged", "transaction_id": args.transaction, "release": str(final_release)}, sort_keys=True))
        except UpdateError:
            shutil.rmtree(candidate, ignore_errors=True)
            shutil.rmtree(install_candidate, ignore_errors=True)
            raise


def switch_current(target):
    current = RELEASES_ROOT / "current"
    temporary = RELEASES_ROOT / f".current.{secrets.token_hex(4)}"
    relative = os.path.relpath(target, RELEASES_ROOT)
    os.symlink(relative, temporary)
    os.replace(temporary, current)
    sync_directory(RELEASES_ROOT)


def stop_appliance(code="SERVICE_STOP_FAILED"):
    for service in (
        "sovereign-local-access.service",
        "nginx.service",
        "sovereign-console.service",
        "sovereign-pihole.service",
    ):
        run_checked(
            [SYSTEMCTL, "stop", service],
            code,
            f"Appliance service could not be stopped: {service}",
        )


def start_appliance(code="SERVICE_START_FAILED"):
    for service in (
        "sovereign-pihole.service",
        "sovereign-console.service",
        "nginx.service",
        "sovereign-local-access.service",
    ):
        run_checked(
            [SYSTEMCTL, "start", service],
            code,
            f"Appliance service could not be started: {service}",
        )


def activate_release(args):
    fail(os.geteuid() == 0 or os.environ.get("SOVEREIGN_UPDATE_TEST_MODE") == "1", "ROOT_REQUIRED", "Activation requires administrator privileges")
    with update_lock():
        snapshot = load_transaction(args.transaction, "staged")
        directory = transaction_path(args.transaction)
        manifest = read_json(directory / "staging/release-manifest.json")
        target = RELEASES_ROOT / "releases" / snapshot["target_version"]
        current = RELEASES_ROOT / "current"
        fail(current.is_symlink(), "ACTIVE_RELEASE_MISSING", "Active release pointer is unavailable")
        previous = current.resolve(strict=True)
        atomic_json(
            directory / "activation.json",
            {
                "schema_version": 1,
                "previous_release": previous.name,
                "target_release": target.name,
            },
        )
        target_digest = manifest["components"]["pihole"]["digest"]
        run_checked([DOCKER, "load", "--input", str(directory / "release-candidate/pihole-arm64.oci.tar")], "IMAGE_IMPORT_FAILED", "Target Pi-hole image could not be imported", timeout=900)
        run_checked([DOCKER, "image", "inspect", target_digest], "IMAGE_DIGEST_MISMATCH", "Imported Pi-hole digest is unavailable")
        snapshot = transition(snapshot, "activating", "ACTIVATION_STARTED")
        qualification_interrupt("activating")
        try:
            stop_appliance()
            switch_current(target)
            start_appliance()
            snapshot = transition(snapshot, "validating", "TARGET_STARTED")
            qualification_interrupt("validating")
            qualification_health_failure()
            run_checked([health_check_command()], "POSTUPDATE_HEALTH_FAILED", "Updated appliance failed health checks")
            snapshot = transition(snapshot, "committed", "UPDATE_COMMITTED", recovery_action="none")
            shutil.rmtree(directory / "release-candidate", ignore_errors=True)
            try:
                (directory / "staging/update-bundle.tar.zst").unlink()
            except OSError:
                pass
            print(json.dumps({"status": "committed", "transaction_id": args.transaction, "version": snapshot["target_version"]}, sort_keys=True))
        except UpdateError as activation_error:
            if snapshot["state"] == "activating":
                snapshot = transition(snapshot, "rolling_back", activation_error.code, failure={"code": activation_error.code, "message": str(activation_error), "retryable": False}, recovery_action="rollback")
            elif snapshot["state"] == "validating":
                snapshot = transition(snapshot, "rolling_back", activation_error.code, failure={"code": activation_error.code, "message": str(activation_error), "retryable": False}, recovery_action="rollback")
            try:
                stop_appliance("ROLLBACK_STOP_FAILED")
                switch_current(previous)
                start_appliance("ROLLBACK_START_FAILED")
                run_checked([health_check_command()], "ROLLBACK_HEALTH_FAILED", "Previous release failed health checks")
                transition(snapshot, "rolled_back", "ROLLBACK_HEALTHY", recovery_action="none")
            except UpdateError as rollback_error:
                transition(snapshot, "recovery_required", rollback_error.code, failure={"code": rollback_error.code, "message": str(rollback_error), "retryable": False}, recovery_action="manual")
            raise


def recover_transactions(_args):
    fail(os.geteuid() == 0 or os.environ.get("SOVEREIGN_UPDATE_TEST_MODE") == "1", "ROOT_REQUIRED", "Recovery audit requires administrator privileges")
    reviewed = []
    with update_lock():
        for state_path in sorted((UPDATE_ROOT / "transactions").glob("*/state.json")):
            snapshot = read_json(state_path, "INVALID_TRANSACTION")
            state = snapshot.get("state")
            transaction_id = snapshot.get("transaction_id")
            if state not in {"backing_up", "activating", "validating", "rolling_back"}:
                continue
            if state in {"activating", "validating", "rolling_back"}:
                activation = read_json(state_path.parent / "activation.json", "RECOVERY_METADATA_MISSING")
                exact_keys(activation, ["schema_version", "previous_release", "target_release"], "activation metadata")
                previous_name = activation["previous_release"]
                fail(isinstance(previous_name, str) and SAFE_ID.fullmatch(previous_name), "RECOVERY_METADATA_INVALID", "Previous release identity is invalid")
                previous = RELEASES_ROOT / "releases" / previous_name
                fail(previous.is_dir(), "RECOVERY_RELEASE_MISSING", "Previous release is unavailable")
                switch_current(previous)
            transition(
                snapshot,
                "recovery_required",
                "INTERRUPTED_TRANSACTION",
                failure={
                    "code": "INTERRUPTED_TRANSACTION",
                    "message": "Update was interrupted before a health-gated terminal state",
                    "retryable": False,
                },
                recovery_action="manual",
            )
            reviewed.append(transaction_id)
    print(json.dumps({"status": "reviewed", "recovery_required": reviewed}, sort_keys=True))


def transaction_event_reasons(directory):
    try:
        return {
            json.loads(line)["reason"]
            for line in (directory / "events.jsonl").read_text().splitlines()
        }
    except (OSError, KeyError, json.JSONDecodeError) as error:
        raise UpdateError(
            "INVALID_TRANSACTION", "Transaction event history is unreadable"
        ) from error


def discard_transaction(args):
    fail(
        os.geteuid() == 0 or os.environ.get("SOVEREIGN_UPDATE_TEST_MODE") == "1",
        "ROOT_REQUIRED",
        "Discarding a transaction requires administrator privileges",
    )
    with update_lock():
        snapshot = load_transaction(args.transaction)
        fail(
            snapshot["state"] in {"rolled_back", "recovery_required"},
            "INVALID_TRANSACTION_STATE",
            "Only rolled-back or recovery-required transactions can be discarded",
        )
        directory = transaction_path(args.transaction)
        current = RELEASES_ROOT / "current"
        fail(
            current.is_symlink(),
            "ACTIVE_RELEASE_MISSING",
            "Active release pointer is unavailable",
        )
        active = current.resolve(strict=True)
        releases = RELEASES_ROOT / "releases"
        target = releases / snapshot["target_version"]
        if target.exists():
            fail(
                "RELEASE_STAGED" in transaction_event_reasons(directory),
                "DISCARD_TARGET_UNOWNED",
                "Transaction did not stage the existing target release",
            )
            fail(
                target.is_dir() and not target.is_symlink(),
                "DISCARD_TARGET_UNSAFE",
                "Target release is not a removable directory",
            )
            fail(
                target.resolve() != active,
                "DISCARD_TARGET_ACTIVE",
                "Cannot discard the active release",
            )
            shutil.rmtree(target)
            sync_directory(releases)
        shutil.rmtree(directory / "release-candidate", ignore_errors=True)
        try:
            (directory / "staging/update-bundle.tar.zst").unlink()
        except FileNotFoundError:
            pass
        sync_directory(directory / "staging")
        snapshot = transition(
            snapshot,
            "discarded",
            "TRANSACTION_DISCARDED",
            recovery_action="none",
        )
        print(
            json.dumps(
                {"status": "discarded", "transaction_id": args.transaction},
                sort_keys=True,
            )
        )


def show_status(_args):
    policy = read_json(POLICY_PATH, "INVALID_POLICY")
    latest = read_json(UPDATE_STATUS_PATH) if UPDATE_STATUS_PATH.is_file() else None
    result = {
        "installed_version": read_release_version(),
        "channel": policy.get("channel"),
        "device": policy.get("device"),
        "update_state": latest["state"] if latest else "idle",
        "target_version": latest["target_version"] if latest else None,
    }
    print(json.dumps(result, sort_keys=True))


def parser():
    command = argparse.ArgumentParser(prog="sovereign-update")
    subcommands = command.add_subparsers(dest="command", required=True)
    status = subcommands.add_parser("status", help="show installed update state")
    status.set_defaults(handler=show_status)
    inspect = subcommands.add_parser("inspect", help="verify a signed local update")
    inspect.add_argument("--manifest", required=True)
    inspect.add_argument("--signature", required=True)
    inspect.add_argument("--artifact")
    inspect.set_defaults(handler=inspect_update)
    prepare = subcommands.add_parser("prepare", help="verify and durably stage a local update")
    prepare.add_argument("--manifest", required=True)
    prepare.add_argument("--signature", required=True)
    prepare.add_argument("--artifact", required=True)
    prepare.set_defaults(handler=prepare_update)
    backup = subcommands.add_parser("backup", help="create a quiesced pre-update backup")
    backup.add_argument("transaction")
    backup.set_defaults(handler=create_backup)
    stage = subcommands.add_parser("stage", help="safely extract a backed-up update")
    stage.add_argument("transaction")
    stage.set_defaults(handler=stage_release)
    activate = subcommands.add_parser("activate", help="activate and health-check a staged update")
    activate.add_argument("transaction")
    activate.set_defaults(handler=activate_release)
    recover = subcommands.add_parser("recover", help="audit interrupted transactions at boot")
    recover.set_defaults(handler=recover_transactions)
    discard = subcommands.add_parser(
        "discard", help="remove inactive payloads from a failed transaction"
    )
    discard.add_argument("transaction")
    discard.set_defaults(handler=discard_transaction)
    return command


def main():
    args = parser().parse_args()
    try:
        validate_qualification_interrupt()
        args.handler(args)
    except UpdateError as error:
        print(json.dumps({"status": "rejected", "code": error.code, "message": str(error)}), file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
