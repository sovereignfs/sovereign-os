#!/bin/bash

set -eu

root=$1
. "${root}/usr/lib/sovereign/docker-engine.env"

install -d -m 0755 "${root}/etc/apt/keyrings"
curl -fsSL https://download.docker.com/linux/debian/gpg \
  -o "${root}/etc/apt/keyrings/docker.asc"
printf '%s  %s\n' \
  "$DOCKER_APT_KEY_SHA256" \
  "${root}/etc/apt/keyrings/docker.asc" | sha256sum -c -
chmod a+r "${root}/etc/apt/keyrings/docker.asc"

cat > "${root}/etc/apt/sources.list.d/docker.sources" <<'EOF'
Types: deb
URIs: https://download.docker.com/linux/debian
Suites: trixie
Components: stable
Architectures: arm64
Signed-By: /etc/apt/keyrings/docker.asc
EOF

chroot "$root" apt-get update
chroot "$root" apt-get \
  -o Dpkg::Options::=--force-confold \
  install -y --no-install-recommends \
  "docker-ce=${DOCKER_CE_VERSION}" \
  "docker-ce-cli=${DOCKER_CE_CLI_VERSION}" \
  "containerd.io=${CONTAINERD_IO_VERSION}" \
  "docker-buildx-plugin=${DOCKER_BUILDX_VERSION}" \
  "docker-compose-plugin=${DOCKER_COMPOSE_VERSION}"

chroot "$root" apt-mark hold \
  docker-ce docker-ce-cli containerd.io \
  docker-buildx-plugin docker-compose-plugin
